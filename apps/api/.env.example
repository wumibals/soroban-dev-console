# ─────────────────────────────────────────────
# API Environment Configuration
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT="4000"

# Allowed CORS origin for the web app
# local:  http://localhost:3000
# demo:   https://your-demo-domain.vercel.app
WEB_ORIGIN="http://localhost:3000"

# ── Database ──────────────────────────────────
# local:  file:./dev.db
# demo:   file:./demo.db   (or a hosted Postgres URL)
DATABASE_URL="file:./dev.db"

# ── Soroban RPC Endpoints ─────────────────────
# Leave the ones you don't use as empty strings.
# The API will warn (not crash) for missing optional endpoints.
SOROBAN_RPC_MAINNET_URL="https://mainnet.stellar.validationcloud.io/v1/<YOUR_KEY>"
SOROBAN_RPC_TESTNET_URL="https://soroban-testnet.stellar.org:443"
SOROBAN_RPC_FUTURENET_URL="https://rpc-futurenet.stellar.org:443"
SOROBAN_RPC_LOCAL_URL="http://localhost:8000/soroban/rpc"

# ── Build / CI ────────────────────────────────
SOROBAN_BUILD_IMAGE="stellar/stellar-cli:latest"

# ── Runtime Mode ──────────────────────────────────────────────────────────────
# Controls which env vars are required vs optional at startup.
# Values: local (default) | demo | ci
# See docs/config-promotion.md for the full promotion workflow.
RUNTIME_MODE="local"

# ── Security Configuration ───────────────────────────────────────────────────
# DEVOPS-002: Security headers are automatically applied:
# - X-Content-Type-Options: nosniff
# - X-Frame-Options: DENY
# - X-XSS-Protection: 0 (modern browsers use CSP)
# - Referrer-Policy: strict-origin-when-cross-origin
#
# CORS Configuration:
# - WEB_ORIGIN controls allowed origins
# - x-owner-key header is NOT advertised in CORS preflight (security measure)
# - x-request-id header is allowed for correlation tracing
#
# Owner Key Requirements:
# - Minimum 8 characters, maximum 256 characters
# - Cannot be common patterns (password, 12345678, admin, etc.)
# - Treated as bearer token - protect like a password
#
# Share Link Security:
# - Maximum expiration: 1 year from creation
# - Maximum snapshot size: 500KB
# - Maximum JSON nesting depth: 10 levels